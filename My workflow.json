      "parameters": {
        "jsCode": "const seen = new Set();\nconst result = [];\n\nfor (const item of items) {\n\n  const orderId = item.json[\"Order ID\"];\n\n  if (seen.has(orderId)) continue;\n  seen.add(orderId);\n\n  // random TAT between 1 and 48 hrs\n  const tat = Math.floor(Math.random() * 48) + 1;\n\n  const sla = tat <= 24 ? \"YES\" : \"NO\";\n  const aht = (tat * 60 / 10).toFixed(2);\n\n  result.push({\n    json: {\n      \"Order ID\": item.json[\"Order ID\"],\n      \"Customer\": item.json[\"Customer\"],\n      \"Product\": item.json[\"Product\"] || \"N/A\",\n      \"TAT (hrs)\": tat,\n      \"SLA Status\": sla,\n      \"AHT (min)\": aht\n    }\n  });\n\n}\n\nreturn result;"
      },
